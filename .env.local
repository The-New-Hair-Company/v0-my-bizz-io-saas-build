# --- Supabase ---
# Found in: Supabase Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://qhajogurnciezpbybxay.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_jw7AxV--kl--vvHyQMSXSg_JrofwDdf

# Service role key — server-only, never expose to browser
# Needed for server-side admin operations
